# ============================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================
# ⚠️  IMPORTANT: Never commit this file to version control
# ⚠️  IMPORTANT: Use strong, unique values for all passwords

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
ENVIRONMENT=production
APP_NAME="Personal AI Assistant"
APP_VERSION=1.0.0

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# PostgreSQL connection settings
DB_USER=prod_user_change_me
DB_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE_40_CHARS_MIN
DB_NAME=personal_assistant_prod
DB_HOST=db
DB_PORT=5432

# ============================================================
# AI MODEL CONFIGURATION
# ============================================================
# Ollama model selection
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODEL=mistral:3b-instruct-q4_K_M
OLLAMA_TIMEOUT=300

# LLM Parameters
LLM_CONTEXT_LENGTH=2048
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TOP_P=0.95

# ============================================================
# SECURITY SETTINGS
# ============================================================
# Generate a secure secret key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY_40_CHARS_MIN
API_KEY_ENABLED=true

# ============================================================
# CORS & DOMAIN SETTINGS
# ============================================================
# Production domains only
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# ============================================================
# API ENDPOINTS
# ============================================================
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
NEXT_PUBLIC_ENVIRONMENT=production

# ============================================================
# LOGGING & MONITORING
# ============================================================
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================
# EXTERNAL SERVICE KEYS (Optional)
# ============================================================
# If using external AI services instead of local Ollama
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# GOOGLE_CLOUD_API_KEY=...
# REPLICATE_API_KEY=...

# ============================================================
# BACKUP & PERSISTENCE
# ============================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours in seconds
