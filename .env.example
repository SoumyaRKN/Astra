# ============================================================
# DEVELOPMENT/LOCAL ENVIRONMENT CONFIGURATION
# ============================================================
# For PRODUCTION: Copy this file to .env.production and update values
# For LOCAL: Copy to .env.local and use default values below

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
# Use: development (for local) or production (for live)
ENVIRONMENT=development
APP_NAME="Personal AI Assistant"
APP_VERSION=1.0.0

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Local PostgreSQL (Docker will start this automatically)
DB_USER=personal_ai
DB_PASSWORD=changeme123
DB_NAME=personal_assistant
DB_HOST=db
DB_PORT=5432

# ============================================================
# AI MODEL CONFIGURATION
# ============================================================
# Ollama configuration (runs in Docker)
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODEL=mistral:3b-instruct-q4_K_M
# Options: mistral, llama2, neural-chat, etc.
OLLAMA_TIMEOUT=300

# ============================================================
# LLM PARAMETERS
# ============================================================
# Context: How many previous messages to remember (higher = slower)
LLM_CONTEXT_LENGTH=2048

# Temperature: 0=precise, 1=creative (use 0-1)
LLM_TEMPERATURE=0.7

# Max tokens: Maximum length of response (higher = slower)
LLM_MAX_TOKENS=512

# Top-P: Nucleus sampling (0-1)
LLM_TOP_P=0.95

# ============================================================
# SECURITY
# ============================================================
# Secret key for encryption (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=dev-secret-key-change-in-production
API_KEY_ENABLED=false

# ============================================================
# CORS & DOMAINS
# ============================================================
# Allowed origins (change for production)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# API endpoint for frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=DEBUG

# ==========================================
# DEPLOYMENT
# ==========================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_IMAGE_TAG=latest
